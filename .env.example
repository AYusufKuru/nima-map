# Kopyala: cp .env.example .env  (Windows: copy .env.example .env)
# .env dosyasını doldur; Git'e eklenmez (.gitignore).

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# EAS bulut derlemesi: https://expo.dev → Proje → Environment variables
# Aynı EXPO_PUBLIC_* anahtarlarını "preview" / "production" ortamına ekleyin.

# Panelden kullanıcı oluşturma: Supabase Edge Function "create-user" deploy edilir.
# BOOTSTRAP_SECRET sadece supabase secrets ile sunucuda tutulur (.env'e yazmayın).
# Adımlar: supabase/EDGE-FUNCTION-KURULUM.txt
