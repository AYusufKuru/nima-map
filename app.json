{
  "expo": {
    "name": "Nima Map",
    "slug": "map-demo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/logo_.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "nimap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "package": "com.morphase.mapdemo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "./plugins/withExpoCropToolbarColors.js",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Kamerayı kullanmak için izne ihtiyacımız var."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Konumunuzu fotoğraflara eklemek için izne ihtiyacımız var."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Fotoğrafları galeriye kaydetmek için izne ihtiyacımız var.",
          "savePhotosPermission": "Fotoğrafları galeriye kaydetmek için izne ihtiyacımız var.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": ["photo"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5adf8c57-8cec-4b19-a4aa-7ad19a3194fe"
      }
    },
    "owner": "nimamapapp"
  }
}
